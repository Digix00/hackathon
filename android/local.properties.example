# local.properties – このファイルは .gitignore で除外してください
# Firebase / API の秘密情報を環境別に記入します

# prod 環境 API ベース URL
prod.api.base_url=https://api.example.com/

# Release 署名（release ビルド時に必須）
release.signing.store_file=/path/to/release-keystore.jks
release.signing.store_password=YOUR_STORE_PASSWORD
release.signing.key_alias=YOUR_KEY_ALIAS
release.signing.key_password=YOUR_KEY_PASSWORD

# Spotify OAuth クライアント情報
spotify.client_id=YOUR_SPOTIFY_CLIENT_ID
spotify.redirect_uri=musicswapping://spotify/callback
