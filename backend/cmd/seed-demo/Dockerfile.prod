# ---- builder ----
FROM golang:1.25-bookworm AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /seed-demo ./cmd/seed-demo

# ---- production ----
FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /seed-demo /seed-demo
CMD ["/seed-demo"]
